{
  "name": "@vectorcrush/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "vectorcrush": "./dist/index.js"
  },
  "scripts": {
    "build": "pnpm --filter @vectorcrush/core build && tsc -p tsconfig.json",
    "dev": "pnpm --filter @vectorcrush/core build && tsx src/index.ts",
    "test": "pnpm --filter @vectorcrush/core build && vitest run",
    "typecheck": "pnpm --filter @vectorcrush/core build && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vectorcrush/core": "workspace:*"
  },
  "devDependencies": {}
}
